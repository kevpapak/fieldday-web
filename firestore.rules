rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public website launch signups
    match /launchSignups/{signupId} {
      allow read, update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          'email',
          'source',
          'page',
          'userAgent',
          'createdAt'
        ]) &&
        request.resource.data.email is string &&
        request.resource.data.email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$') &&
        request.resource.data.email.size() <= 254 &&
        request.resource.data.source == 'fieldday-website' &&
        request.resource.data.page is string &&
        request.resource.data.page.size() <= 2048 &&
        request.resource.data.userAgent is string &&
        request.resource.data.userAgent.size() <= 512 &&
        request.resource.data.createdAt == request.time;
    }

    // Users
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Follows
    match /follows/{followId} {
      allow read, write: if request.auth != null;
    }

    // Direct messages
    match /directMessages/{dmId} {
      allow read, write: if request.auth != null &&
        request.auth.uid in resource.data.participants;
      allow create: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Game chats
    match /chats/{chatId} {
      allow read, write: if request.auth != null;
      match /messages/{msgId} {
        allow read, write: if request.auth != null;
      }
    }

    // Games
    match /games/{gameId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.hostId;
      allow update: if request.auth != null;
    }

    // Team invites
    match /teamInvites/{inviteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }

    // Clubs + all subcollections
    match /clubs/{clubId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.ownerId ||
         request.auth.uid in resource.data.admins);

      match /posts/{postId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow delete: if request.auth != null &&
          request.auth.uid == resource.data.authorId;
      }

      match /teams/{teamId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null;
        allow update, delete: if request.auth != null;
      }

      match /leagues/{leagueId} {
        allow read: if request.auth != null;
        allow create, update: if request.auth != null;

        match /teams/{teamId} {
          allow read: if request.auth != null;
          allow create, update, delete: if request.auth != null;
        }

        match /matches/{matchId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null;
        }

        match /standings/{standingId} {
          allow read: if request.auth != null;
          allow write: if request.auth != null;
        }

        match /registrations/{regId} {
          allow read: if request.auth != null;
          allow create: if request.auth != null;
          allow update: if request.auth != null;
        }
      }
    }
  }
}